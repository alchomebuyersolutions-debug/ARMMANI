// ══════════════════════════════════════════════════════════════════════
// ORB — Opening Range Breakout Strategy (NQ / ES / MNQ / MES)
// Author: AlphaWik99 / Squad
// Version: 1.0
// ══════════════════════════════════════════════════════════════════════
//
// SETUP:
// 1. Paste this into TradingView Pine Editor
// 2. Add to NQ 5min chart
// 3. Set alerts: "Any alert() function call"
// 4. Webhook URL → Tradesyncer (Apex) + Algoway (MT5 live)
//
// RULES:
// - Opening range = first N minutes after market open (default: 15min)
// - LONG when price closes above range HIGH
// - SHORT when price closes below range LOW
// - Stop loss = opposite side of the range
// - Take profit = configurable R:R (default 2:1)
// - Max 1 trade per day per direction
// - No new entries after cutoff time (default 2:00 PM ET)
// ══════════════════════════════════════════════════════════════════════

//@version=6
strategy("ORB — Opening Range Breakout", overlay=true, default_qty_type=strategy.fixed, default_qty_value=1, initial_capital=50000, commission_type=strategy.commission.cash_per_contract, commission_value=2.5)

// ── Inputs ──────────────────────────────────────────────────────────
grp_orb = "Opening Range"
orbMinutes       = input.int(15, "Opening Range (minutes)", minval=5, maxval=60, step=5, group=grp_orb)
sessionStartHour = input.int(9, "Session Start Hour (ET)", minval=0, maxval=23, group=grp_orb)
sessionStartMin  = input.int(30, "Session Start Minute", minval=0, maxval=59, group=grp_orb)

grp_trade = "Trade Management"
rrRatio          = input.float(2.0, "Risk:Reward Ratio", minval=0.5, maxval=5.0, step=0.5, group=grp_trade)
useTrailingStop  = input.bool(false, "Use Trailing Stop", group=grp_trade)
trailTicks       = input.int(20, "Trailing Stop (ticks)", minval=5, maxval=100, group=grp_trade)
maxTradesPerDay  = input.int(2, "Max Trades Per Day", minval=1, maxval=10, group=grp_trade)

grp_filter = "Filters"
cutoffHour       = input.int(14, "No New Trades After (Hour ET)", minval=10, maxval=16, group=grp_filter)
cutoffMin        = input.int(0, "No New Trades After (Minute)", minval=0, maxval=59, group=grp_filter)
minRangePoints   = input.float(5.0, "Min Range Size (points)", minval=1.0, maxval=50.0, group=grp_filter)
maxRangePoints   = input.float(80.0, "Max Range Size (points)", minval=10.0, maxval=200.0, group=grp_filter)

grp_alert = "Alert Settings"
enableAlerts     = input.bool(true, "Enable Webhook Alerts", group=grp_alert)

// ── Time Calculations (ET timezone) ─────────────────────────────────
// TradingView uses exchange timezone for futures
currentHour = hour(time, "America/New_York")
currentMin  = minute(time, "America/New_York")
currentTimeMin = currentHour * 60 + currentMin

sessionStartTimeMin = sessionStartHour * 60 + sessionStartMin
orbEndTimeMin       = sessionStartTimeMin + orbMinutes
cutoffTimeMin       = cutoffHour * 60 + cutoffMin

isORBWindow   = currentTimeMin >= sessionStartTimeMin and currentTimeMin < orbEndTimeMin
isTradeWindow = currentTimeMin >= orbEndTimeMin and currentTimeMin < cutoffTimeMin
isNewDay      = currentTimeMin == sessionStartTimeMin and (currentTimeMin != currentTimeMin[1] or barstate.isfirst)

// ── Track Opening Range ─────────────────────────────────────────────
var float orbHigh = na
var float orbLow  = na
var bool  orbSet  = false
var int   dailyTrades = 0

// Reset at session start
if isNewDay
    orbHigh := high
    orbLow  := low
    orbSet  := false
    dailyTrades := 0

// Build the range during ORB window
if isORBWindow
    orbHigh := na(orbHigh) ? high : math.max(orbHigh, high)
    orbLow  := na(orbLow) ? low : math.min(orbLow, low)

// Mark range as set when ORB window ends
if currentTimeMin >= orbEndTimeMin and not orbSet and not na(orbHigh) and not na(orbLow)
    orbSet := true

// ── Range Calculations ──────────────────────────────────────────────
orbRange   = orbSet ? orbHigh - orbLow : na
rangeValid = orbSet and orbRange >= minRangePoints and orbRange <= maxRangePoints

// ── Entry Conditions ────────────────────────────────────────────────
longCondition  = rangeValid and isTradeWindow and close > orbHigh and close[1] <= orbHigh and dailyTrades < maxTradesPerDay and strategy.position_size == 0
shortCondition = rangeValid and isTradeWindow and close < orbLow and close[1] >= orbLow and dailyTrades < maxTradesPerDay and strategy.position_size == 0

// ── Execute Trades ──────────────────────────────────────────────────
if longCondition
    stopLoss   = orbLow
    takeProfit = close + (close - orbLow) * rrRatio

    strategy.entry("ORB Long", strategy.long)

    if useTrailingStop
        strategy.exit("ORB Long Exit", "ORB Long", trail_points=trailTicks, trail_offset=trailTicks/2, stop=stopLoss)
    else
        strategy.exit("ORB Long Exit", "ORB Long", stop=stopLoss, limit=takeProfit)

    dailyTrades += 1

    if enableAlerts
        alert('{"action":"buy","ticker":"' + syminfo.ticker + '","price":' + str.tostring(close) + ',"sl":' + str.tostring(stopLoss) + ',"tp":' + str.tostring(takeProfit) + ',"strategy":"ORB","range":' + str.tostring(orbRange) + '}', alert.freq_once_per_bar_close)

if shortCondition
    stopLoss   = orbHigh
    takeProfit = close - (orbHigh - close) * rrRatio

    strategy.entry("ORB Short", strategy.short)

    if useTrailingStop
        strategy.exit("ORB Short Exit", "ORB Short", trail_points=trailTicks, trail_offset=trailTicks/2, stop=stopLoss)
    else
        strategy.exit("ORB Short Exit", "ORB Short", stop=stopLoss, limit=takeProfit)

    dailyTrades += 1

    if enableAlerts
        alert('{"action":"sell","ticker":"' + syminfo.ticker + '","price":' + str.tostring(close) + ',"sl":' + str.tostring(stopLoss) + ',"tp":' + str.tostring(takeProfit) + ',"strategy":"ORB","range":' + str.tostring(orbRange) + '}', alert.freq_once_per_bar_close)

// ── Close at end of day (no overnight holds) ────────────────────────
if currentTimeMin >= 15 * 60 + 55 and strategy.position_size != 0  // 3:55 PM ET
    strategy.close_all("EOD Close")
    if enableAlerts
        alert('{"action":"flat","ticker":"' + syminfo.ticker + '","strategy":"ORB","reason":"EOD"}', alert.freq_once_per_bar_close)

// ── Visual: Plot Opening Range ──────────────────────────────────────
orbHighLine = plot(orbSet ? orbHigh : na, "ORB High", color=color.new(color.green, 30), linewidth=2, style=plot.style_linebr)
orbLowLine  = plot(orbSet ? orbLow : na, "ORB Low", color=color.new(color.red, 30), linewidth=2, style=plot.style_linebr)
fill(orbHighLine, orbLowLine, color=color.new(color.blue, 90), title="ORB Zone")

// ── Visual: ORB Window Background ───────────────────────────────────
bgcolor(isORBWindow ? color.new(color.yellow, 93) : na, title="ORB Window")
bgcolor(isTradeWindow and rangeValid ? color.new(color.green, 97) : na, title="Trade Window")

// ── Info Table ──────────────────────────────────────────────────────
var table infoTable = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80), border_color=color.gray, border_width=1)

if barstate.islast
    table.cell(infoTable, 0, 0, "ORB High", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, orbSet ? str.tostring(orbHigh, "#.##") : "Building...", text_color=color.green, text_size=size.small)
    table.cell(infoTable, 0, 1, "ORB Low", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 1, orbSet ? str.tostring(orbLow, "#.##") : "Building...", text_color=color.red, text_size=size.small)
    table.cell(infoTable, 0, 2, "Range", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 2, orbSet ? str.tostring(orbRange, "#.##") + " pts" : "—", text_color=color.yellow, text_size=size.small)
    table.cell(infoTable, 0, 3, "Trades Today", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 3, str.tostring(dailyTrades) + "/" + str.tostring(maxTradesPerDay), text_color=color.white, text_size=size.small)
    table.cell(infoTable, 0, 4, "Status", text_color=color.white, text_size=size.small)
    statusText = isORBWindow ? "BUILDING RANGE" : isTradeWindow and rangeValid ? "READY TO TRADE" : "MARKET CLOSED"
    statusColor = isORBWindow ? color.yellow : isTradeWindow and rangeValid ? color.green : color.gray
    table.cell(infoTable, 1, 4, statusText, text_color=statusColor, text_size=size.small)
